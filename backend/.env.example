# Copy to .env and fill in your values

# Hugging Face token (required for gated models)
HF_TOKEN=

# Model precision: bf16 (default, ~16GB) or int4 (~8GB)
MODEL_PRECISION=bf16

# Inference device: auto | cuda | mps | cpu
INFERENCE_DEVICE=auto

# CORS: allow requests from this origin (default: Vite dev server)
ALLOWED_ORIGIN=http://localhost:5173

# Enable Flask debug mode (never true in production)
FLASK_DEBUG=false

# Max video upload size in MB
MAX_UPLOAD_MB=200

# Optional: custom Hugging Face model cache directory
# HF_HOME=/path/to/hf_cache
